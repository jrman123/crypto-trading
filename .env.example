# Copy these into Vercel Environment Variables or a local .env for on-prem
BINANCE_API_KEY=YOUR_KEY_HERE
BINANCE_API_SECRET=YOUR_SECRET_HERE
# Use https://api.binance.us for US, https://api.binance.com for global
BINANCE_BASE_URL=https://api.binance.us
BINANCE_TESTNET=true
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
MAX_QUOTE_PER_TRADE_USD=20
ZAPIER_WEBHOOK_URL=
LOG_LEVEL=info

# PostgreSQL Database Configuration (for Trading Knowledge System)
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_trading
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_trading
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Web Intelligence Configuration
WEB_INTELLIGENCE_ENABLED=true
NEWS_API_KEY=
NEWS_UPDATE_INTERVAL_MS=300000
