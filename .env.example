# ============================================================
# Trade Knowledge System - Environment Configuration
# ============================================================

# PostgreSQL Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trade_knowledge
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_me_in_production

# Service Execution Intervals (in seconds)
# How often each service runs its cycle
INGEST_EVERY=3600        # 1 hour - fetch new price data
FEATURES_EVERY=1800      # 30 minutes - compute indicators
SIGNALS_EVERY=1800       # 30 minutes - generate signals
EXECUTE_EVERY=3600       # 1 hour - execute trades
WEB_EVERY=7200           # 2 hours - monitor news

# Execution Mode
# PAPER = simulated trading (safe)
# LIVE = real exchange trading (use with caution)
EXECUTION_MODE=PAPER
# Trading Knowledge System Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=trading_knowledge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# Exchange API Configuration
# ============================================
EXCHANGE=binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# ============================================
# Trading Configuration
# ============================================
# Trading mode: paper (simulation) or live (real money)
TRADING_MODE=paper

# ============================================
# Service Update Intervals (seconds)
# ============================================
# How often to fetch new candle data
INGESTOR_INTERVAL_SECONDS=60

# How often to compute technical indicators
FEATURE_BUILDER_INTERVAL_SECONDS=60

# How often to generate new signals
SIGNAL_ENGINE_INTERVAL_SECONDS=120

# How often to check for signals to execute
EXECUTION_BOT_INTERVAL_SECONDS=30

# How often to check for news/web intelligence
WEB_AGENT_INTERVAL_SECONDS=300

# ============================================
# Optional: External API Keys
# ============================================
# CryptoCompare News API (optional)
# CRYPTOCOMPARE_API_KEY=

# Reddit API (optional)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Twitter API (optional)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# PostgreSQL Database Configuration (for Trading Knowledge System)
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_trading
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_trading
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Web Intelligence Configuration
WEB_INTELLIGENCE_ENABLED=true
NEWS_API_KEY=
NEWS_UPDATE_INTERVAL_MS=300000
